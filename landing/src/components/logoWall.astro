---
const technologies = [
	// Lenguajes Core
	"HTML5",
	"CSS3",
	"javaScript",
	"typeScript",
	// Estilos y Diseño
	"Bootstrap",
	"tailwindcss",
	// Frameworks y Librerías
	"jQuery",
	"astro",
	"vue",
	"react",
	"next",
	// Lenguajes y Entornos
	"PHP",
	"Python",
	"nodejs",
	// Frameworks
	"Laravel",
	"Django",
	// Bases de Datos
	"mysql",
	"PostgreSQL",
	"supabase",
	// Gestión de Contenidos (CMS)
	"Joomla",
	"WordPress",
	"Shopify",
	// Aplicaciones Híbridas / Multiplataforma
	"Ionic",
	// Aplicaciones Nativas
	"Electron",
	// Servidores y Cloud
	"AWS",
	"DigitalOcean",
	// Plataformas de Despliegue Rápido
	"Cloudflare",
	"Netlify",
	"vercel",
	// Sistemas y Consola
	"bash",
	// Control de Versiones
	"git",
	// IA
	"Claude",
	"Gemini",
];
---

<div class="relative overflow-x-hidden py-8">
	<div class="pointer-events-none absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[var(--background)] to-transparent z-20"></div>
	<div class="pointer-events-none absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[var(--background)] to-transparent z-20"></div>
	<div class="flex animate-scroll hover:animate-paused gap-12 md:gap-20 w-max">
		{
			[...technologies, ...technologies, ...technologies].map(( tech ) => (
				<div class="flex items-center gap-2 group transition-all duration-300">
					<img
						src={`/svg/${tech}.svg`}
						alt={tech}
						class="h-7 w-auto object-contain transition-transform group-hover:scale-110 opacity-80"
						width="30"
						height="30"
						loading="lazy"
					/>
					<span class="text-lg font-medium text-[var(--white-icon)]">
						{tech.charAt( 0 ).toUpperCase() + tech.slice( 1 )}
					</span>
				</div>
			))
		}
	</div>
</div>

<style is:global>
	@keyframes scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}
	.animate-scroll {
		animation: scroll 60s linear infinite;
	}
	@media (min-width: 768px) {
		.animate-scroll {
			animation-duration: 50s;
		}
	}
</style>
